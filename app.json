{
  "expo": {
    "name": "PharmacyAppStable",
    "slug": "PharmacyAppStable",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "config": {
        "usesCleartextTraffic": true
      },
      "package": "com.shobeee.PharmacyAppStable"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.pharmacyapp",
          "enableGooglePay": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow $(PRODUCT_NAME) to access your location to fill your address.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location to fill your address."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "43ce51a9-9a31-4b99-bc03-4814d127592d"
      }
    }
  }
}
